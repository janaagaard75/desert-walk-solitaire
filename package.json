{
  "name": "desert-walk",
  "version": "1.0.9",
  "description": "Solitaire card game for iOS and Android using React Native, Expo, MobX and TypeScript.",
  "author": {
    "email": "jan@aagaard.net",
    "name": "Jan Aagaard"
  },
  "private": true,
  "license": "MIT",
  "main": "expo/AppEntry.js",
  "jest": {
    "preset": "jest-expo-ts"
  },
  "expo": {
    "doctor": {
      "reactNativeDirectoryCheck": {
        "listUnknownPackages": false
      }
    }
  },
  "scripts": {
    "build": "yarn run eas build",
    "check-lint": "eslint --format unix --max-warnings 0",
    "check-types": "tsc",
    "docs-clean": "rm -rf docs/_site",
    "docs-install": "(cd docs; bundle install)",
    "docs-start": "yarn run docs-clean && (cd docs; bundle exec jekyll serve --future --unpublished)",
    "docs-update": "(cd docs; bundle update)",
    "eas": "yarn dlx --package eas-cli --quiet eas",
    "//": "Corepack must be enabled for EAS builds to ensure the correct package manager (Yarn) is available in the build environment.",
    "eas-build-pre-install": "corepack enable",
    "start": "expo start",
    "submit": "yarn run eas submit",
    "update": "yarn run eas update"
  },
  "dependencies": {
    "@eslint/js": "^9.39.4",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@types/react": "~19.2.10",
    "@typescript-eslint/eslint-plugin": "^8.58.2",
    "@typescript-eslint/parser": "^8.58.2",
    "eslint": "^9.39.4",
    "eslint-formatter-unix": "^9.0.1",
    "eslint-plugin-filename-export": "^2.0.0",
    "eslint-plugin-perfectionist": "^5.9.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-hooks-extra": "^2.13.0",
    "eslint-plugin-react-native": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.5.2",
    "expo": "^55.0.15",
    "expo-font": "~55.0.6",
    "expo-screen-orientation": "~55.0.13",
    "expo-splash-screen": "~55.0.18",
    "expo-updates": "~55.0.20",
    "globals": "^17.5.0",
    "mobx": "^6.13.7",
    "mobx-react": "^9.2.0",
    "prettier": "^3.6.2",
    "react": "19.2.0",
    "react-native": "0.83.4",
    "react-native-svg": "15.15.3",
    "tslib": "^2.6.3",
    "typescript": "~5.9.2",
    "typescript-eslint": "^8.58.2"
  },
  "packageManager": "yarn@4.14.1"
}
